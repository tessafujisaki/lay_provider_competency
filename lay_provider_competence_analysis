``` {r, GEE_analysis_individual_univariate}

# Load required packages
library(tidyr)
library(purrr)

run_gee <- function(var) {
 # Select outcome + predictor + ID
  df <- final_df %>%
    select(equip_total, facility_id_equip, all_of(var)) %>%
    drop_na()

  # Build formula
  formula <- as.formula(paste("equip_total ~", var))
  
  model <- geeglm(
    formula,
    data = df,
    id = facility_id_equip,
    family = gaussian, 
    corstr = "exchangeable"
  )

  list(
    model = summary(model),
    ci = tidy(model, conf.int = TRUE)
  )
}

# Univariate individual-level variables GEE 
vars <- c(
  "cadre", "age_category", "sex", "education_category", "yearsjob",
  "yearswork", "stigma_mean", "oric_mean", "aaf_mean", 
  "aim_mean", "iam_mean", "fim_mean"
)

gee_results <- lapply(vars, run_gee)
names(gee_results) <- vars

# View individual-level univariate results 
gee_results$cadre          # results for cadre
gee_results$age_category   # results for age_category
gee_results$sex            # results for sex
gee_results$education_category  # results for education_category
gee_results$yearsjob       # results for yearsjob 
gee_results$yearswork      # results for yearswork
gee_results$stigma_mean    # results for stigma_mean
gee_results$oric_mean      # results for sex
gee_results$aaf_mean       # results for aaf_mean
gee_results$aim_mean       # results for aim_mean
gee_results$iam_mean       # results for iam_mean
gee_results$fim_mean       # results for fim_mean

# Calculate confidence intervals for all individual-level variables 
get_gee_ci <- function(var, data) {
  df <- data %>%
    select(equip_total, facility_id_equip, all_of(var)) %>%
    drop_na()
  
  model <- geeglm(
    as.formula(paste("equip_total ~", var)),
    data = df,
    id = facility_id_equip,
    family = gaussian,
    corstr = "exchangeable"
  )
  
  tidy(model, conf.int = TRUE, conf.level = 0.95) %>%
    mutate(variable = var) %>%
    select(variable, term, conf.low, conf.high)
}
gee_cis_uni_indv <- map_dfr(vars, ~get_gee_ci(.x, final_df))

# View the confidence intervals
print(gee_cis_uni_indv)


