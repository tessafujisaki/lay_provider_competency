  mutate(across(starts_with("oric_"), ~ case_when(
    . == "1: Completely disagree" | . == "Completely disagree" ~ 1,
    . == "2: Disagree" | . == "Disagree" ~ 2,
    . == "3: Neither agree nor disagree" | . == "Neither agree nor disagree" ~ 3,
    . == "4: Agree" | . == "Agree" ~ 4,
    . == "5: Completely agree" | . == "Completely agree" ~ 5,
    . == "Prefer not to answer" ~ NA_real_,
    TRUE ~ NA_real_
  )))


# Reverse code ORIC-related variables
final_df <- final_df %>%
  mutate(across(c("oric_demand_2_hcw", "oric_demand_3_hcw", "oric_context_2_hcw", "oric_capacity_2_hcw", 
                  "oric_flex_1_hcw", "oric_demand_2_fic", "oric_demand_3_fic", "oric_capacity_2_fic", 
                  "oric_context_2_fic"),
                ~6 - .))


# Assign stigma scores
