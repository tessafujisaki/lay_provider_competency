  mutate(across(
    starts_with("stigma_"), 
    ~ case_when(
      . == "1: Completely disagree" ~ 1,
      . == "2: Disagree" ~ 2,
      . == "3: Neither agree nor disagree" ~ 3,
      . == "4: Agree" ~ 4,
      . == "5: Completely agree" ~ 5,
      TRUE ~ NA_real_  # Handles all other cases safely
    )
  ))

 
